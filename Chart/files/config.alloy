livedebugging {
	enabled = true
}

loki.write "loki" {
	endpoint {
		url = format("http://%s:%s/loki/api/v1/push", "{{ .Values.loki.host }}", "{{ .Values.loki.port }}")
	}
}

prometheus.remote_write "prometheus" {
	endpoint {
		url = format("http://%s:%s/api/v1/write", "{{ .Values.prometheus.host }}", "{{ .Values.prometheus.port }}")
	}
}
